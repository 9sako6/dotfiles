[user]
	email = 9sako6@gmail.com
	name = Yutaro Taira
[core]
	excludesfile = ~/.gitignore_global
	hooksPath = ~/.config/git/hooks
	commentchar = ~
	editor = vim -c \"set fenc=utf-8\"
	ignorecase = false
[alias]
	commit-to-add = reset --soft HEAD~1
	add-to-diff = "!f() { if [ \"$#\" -eq 0 ]; then git restore --staged .; else git restore --staged -- \"$@\"; fi; }; f"
