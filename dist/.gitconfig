[user]
	email = 9sako6@gmail.com
	name = Yutaro Taira
[core]
	excludesfile = ~/.gitignore_global
	commentchar = ~
	editor = vim -c \"set fenc=utf-8\"
	ignorecase = false
[hook "public-document-privacy"]
	event = pre-commit
	command = \"$HOME/.config/git/hooks/check-public-document-privacy\"
[hook "gitleaks"]
	event = pre-commit
	command = \"$HOME/.config/git/hooks/run-gitleaks-pre-commit\"
[alias]
	undo = "!f() { \"${HOME}/mybin/git-undo\" \"$@\"; }; f"
