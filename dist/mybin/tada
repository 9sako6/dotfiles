#!/bin/sh
set -eu

platform_name="${TADA_UNAME:-$(uname -s 2>/dev/null || printf 'unknown')}"
if [ "$platform_name" != "Darwin" ]; then
  exit 0
fi

nohup_bin="${TADA_NOHUP_BIN:-$(command -v nohup 2>/dev/null || true)}"
if [ -z "$nohup_bin" ]; then
  exit 0
fi

script_path=$0
case "$script_path" in
  */*) ;;
  *) script_path="$(command -v -- "$script_path" 2>/dev/null || printf '%s' "$script_path")" ;;
esac

readlink_bin="${TADA_READLINK_BIN:-$(command -v readlink 2>/dev/null || true)}"
if [ -n "$readlink_bin" ]; then
  while [ -L "$script_path" ]; do
    link_target="$("$readlink_bin" "$script_path" 2>/dev/null || true)"
    if [ -z "$link_target" ]; then
      break
    fi
    case "$link_target" in
      /*) script_path="$link_target" ;;
      *) script_path="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)/$link_target" ;;
    esac
  done
fi

script_dir=$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)
bin_path="${TADA_BIN_PATH:-$script_dir/lib/tada-darwin-arm64}"
if [ ! -x "$bin_path" ]; then
  exit 0
fi

"$nohup_bin" "$bin_path" >/dev/null 2>&1 &
exit 0
